   "source": [
    "import numpy as np\n",
    "\n",
    "df_monthly = df_merged.groupby(['deviceId', 'year', 'month'])[cols_to_mean].mean().reset_index()\n",
    "df_monthly.head()\n",
    "metadata_subset = ['deviceId', 'latitude', 'longitude', 'deviceType', 'period', 'year', 'month']\n",
    "df_metadata = df_merged[metadata_subset].drop_duplicates(subset=['deviceId', 'year', 'month'])\n",
    "\n",
    "df_final_monthly = df_monthly.merge(df_metadata, on=['deviceId', 'year', 'month'], how='left')\n",
    "\n",
    "df_final_monthly['period'] = np.where(df_final_monthly['x2'].isna(), 'test', 'train')\n",
    "\n",
    "df_final_monthly.head()"
   ]
  },
