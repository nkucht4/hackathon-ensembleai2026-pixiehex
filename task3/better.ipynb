   "source": [
    "from xgboost import XGBRegressor\n",
    "\n",
    "features = [\n",
    "    'month_sin', 'month_cos', \n",
    "    't1', 't1_sq', 't1_cubed',  # Nieliniowa temperatura\n",
    "    't2', 't3', 't4', 't5', 't6', \n",
    "    'latitude', 'longitude', \n",
    "    'deviceType', \n",
    "    'temp_diff_ext_int', \n",
    "    'CDD',                      # Sygnał chłodzenia\n",
    "    'temp_priority',            # Interakcja sprzętowa\n",
    "    'temp_month'                # Interakcja sezonowa\n",
    "]\n",
    "features = features + ['temp_deviation', 'hot_device']\n",
    "\n",
    "train_df = df_final_monthly[df_final_monthly['period'] == 'train'].dropna(subset=['x2'])\n",
    "test_df = df_final_monthly[df_final_monthly['period'] == 'test']\n",
    "\n",
    "X_train = train_df[features]\n",
    "y_train = train_df['x2']\n",
    "\n",
    "X_test = test_df[features]\n",
    "\n",
    "print(f\"Rozmiar treningu: {X_train.shape[0]} wierszy\")\n",
    "print(f\"Rozmiar testu: {X_test.shape[0]} wierszy\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 60,
   "id": "ac1af271",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Plik submission.csv gotowy. Liczba wierszy: 3600\n"
     ]
    }
   ],
   "source": [
    "# 3. Inicjalizacja i trening modelu\n",
    "model = XGBRegressor(n_estimators=200, learning_rate=0.03, max_depth=7, random_state=42)\n",
    "model.fit(X_train, y_train)\n",
    "\n",
    "test_df = test_df.copy()\n",
    "test_df['prediction'] = model.predict(X_test)\n",
    "\n",
    "all_devices = df_device['deviceId'].unique()\n",
    "skeleton = pd.MultiIndex.from_product(\n",
    "    [all_devices, [2025], [5, 6, 7, 8, 9, 10]], \n",
    "    names=['deviceId', 'year', 'month']\n",
    ").to_frame(index=False)\n",
    "\n",
    "submission = skeleton.merge(\n",
    "    test_df[['deviceId', 'year', 'month', 'prediction']], \n",
    "    on=['deviceId', 'year', 'month'], \n",
    "    how='left'\n",
    ")\n",
    "\n",
    "submission['prediction'] = submission.groupby('month')['prediction'].transform(lambda x: x.fillna(x.mean()))\n",
    "submission['prediction'] = submission['prediction'].fillna(y_train.mean())\n",
    "\n",
    "submission.loc[(submission['month'].isin([6,7,8])) & (submission['prediction'] < 0.15), 'prediction'] *= 1.5\n",
    "submission[['deviceId', 'year', 'month', 'prediction']].to_csv('submission.csv', index=False)\n",
    "\n",
    "print(f\"Plik submission.csv gotowy. Liczba wierszy: {len(submission)}\")"
   ]
