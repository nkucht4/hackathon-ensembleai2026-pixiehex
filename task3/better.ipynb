   "source": [
    "from sklearn.metrics import mean_absolute_error\n",
    "from xgboost import XGBRegressor\n",
    "from lightgbm import LGBMRegressor\n",
    "from sklearn.ensemble import RandomForestRegressor\n",
    "from catboost import CatBoostRegressor\n",
    "\n",
    "# 1. Podział na zbiór do nauki i zbiór do sprawdzenia (MAE)\n",
    "# Uczymy się na wszystkim do marca, sprawdzamy na kwietniu\n",
    "train_idx = (train_df['year'] == 2024) | (train_df['month'] < 4)\n",
    "val_idx = (train_df['year'] == 2025) & (train_df['month'] == 4)\n",
    "\n",
    "X_fit, y_fit = X_train[train_idx], y_train[train_idx]\n",
    "X_val, y_val = X_train[val_idx], y_train[val_idx]\n",
    "\n",
    "models = {\n",
    "    'XGBoost': XGBRegressor(n_estimators=300, learning_rate=0.05, max_depth=7, random_state=42, verbosity=0),\n",
    "    'LightGBM': LGBMRegressor(n_estimators=300, learning_rate=0.05, num_leaves=31, random_state=42, verbose=-1),\n",
    "    'RandomForest': RandomForestRegressor(n_estimators=100, max_depth=10, n_jobs=-1, random_state=42),\n",
    "    'CatBoost': CatBoostRegressor(n_estimators=300, learning_rate=0.05, depth=7, random_seed=42, verbose=0)\n",
    "}\n",
    "\n",
    "results = {}\n",
    "\n",
    "print(\"--- Ranking Modeli (MAE na Kwietniu 2025) ---\")\n",
    "for name, model in models.items():\n",
    "    model.fit(X_fit, y_fit)\n",
    "    preds = model.predict(X_val)\n",
    "    mae = mean_absolute_error(y_val, preds)\n",
    "    results[name] = mae\n",
    "    print(f\"{name}: MAE = {mae:.6f}\")\n",
    "\n",
    "best_model_name = min(results, key=results.get)\n",
    "print(f\"\\nNajlepszy model: {best_model_name} z MAE = {results[best_model_name]:.6f}\")\n",
    "\n",
    "final_model = models[best_model_name]\n",
    "final_model.fit(X_train, y_train)\n",
    "\n",
    "test_df['prediction'] = final_model.predict(X_test)"
   ]
