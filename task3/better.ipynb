   "source": [
    "base = \"/net/tscratch/people/tutorial231/hackathon-ensembleai2026-pixiehex/data/\"\n",
    "path_device = base + \"devices.csv\"\n",
    "path_data = base + \"data.csv\"\n",
    "\n",
    "df_device = pd.read_csv(path_device)\n",
    "\n",
    "reader = pd.read_csv(path_data, chunksize=1000000)\n",
    "\n",
    "all_sampled_chunks = []\n",
    "\n",
    "for chunk in tqdm(reader, desc=\"Wczytywanie i slicing\"):\n",
    "    sampled = chunk.iloc[::12].copy()\n",
    "    \n",
    "    all_sampled_chunks.append(sampled)\n",
    "\n",
    "\n",
    "df_data_sampled = pd.concat(all_sampled_chunks, ignore_index=True)"
   ]
