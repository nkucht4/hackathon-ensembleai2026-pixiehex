   "source": [
    "df_final_monthly['month_sin'] = np.sin(2 * np.pi * df_final_monthly['month'] / 12)\n",
    "df_final_monthly['month_cos'] = np.cos(2 * np.pi * df_final_monthly['month'] / 12)"
   ]
  },
